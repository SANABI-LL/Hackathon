# ── CockroachDB Cloud Serverless ──
DATABASE_URL="postgresql://<user>:<pass>@<host>:26257/<db>?sslmode=verify-full"

# ── AWS (本地开发用 key；部署到 AWS 用 IAM role，不要提交 key) ──
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ── Bedrock 模型 (ID 以 Model Access 里实际批到的为准，可能需 us. 跨区域推理档) ──
BEDROCK_CLAUDE_MODEL_ID="us.anthropic.claude-3-5-sonnet-20241022-v2:0"
BEDROCK_TITAN_MODEL_ID="amazon.titan-embed-text-v2:0"

# ── S3 ──
S3_BUCKET="deadline-copilot-docs"

# ── Demo 单用户 (咬死单用户，hardcode 一个 UUID) ──
APP_USER_ID="00000000-0000-0000-0000-000000000001"
