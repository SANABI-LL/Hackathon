# 复制本文件为 web/.env.local 并填入真实值（.env.local 已被 git 忽略，勿提交）
#   cp web/.env.example web/.env.local

# ── CockroachDB Cloud Serverless ──
DATABASE_URL="postgresql://<user>:<pass>@<host>:26257/defaultdb?sslmode=verify-full"

# ── AWS (本地开发用 key；勿提交) ──
AWS_REGION="us-east-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ── Bedrock 模型 (us-east-2 用 us. 跨区推理档) ──
BEDROCK_CLAUDE_MODEL_ID="us.anthropic.claude-sonnet-4-5-20250929-v1:0"
BEDROCK_TITAN_MODEL_ID="amazon.titan-embed-text-v2:0"

# ── S3 ──
S3_BUCKET="deadline-copilot-docs-938050482316"

# ── Demo 单用户 ──
APP_USER_ID="00000000-0000-0000-0000-000000000001"
